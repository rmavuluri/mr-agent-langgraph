PORT=3001
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/mr_agent?schema=public"

# Agent (POST /api/chat): set one provider's key (or LLM_PROVIDER if multiple keys exist).
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...   # or GOOGLE_API_KEY
# LLM_PROVIDER=openai  # openai | anthropic | gemini

# Optional: lock orchestrator: direct | memory | reactive (empty = LLM routes). "research" → direct.
# AGENT_DEFAULT_ROUTE=direct

# Tavily (Research agent web search) — https://app.tavily.com
# TAVILY_API_KEY=tvly-...
